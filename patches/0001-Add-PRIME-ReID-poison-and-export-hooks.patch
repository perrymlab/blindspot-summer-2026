index 6c91ff0..aeaaca7 100644
--- a/fast_reid/fast_reid_interfece.py
+++ b/fast_reid/fast_reid_interfece.py
@@ -1,6 +1,8 @@
 import cv2
+import csv
 import numpy as np
 import matplotlib.pyplot as plt
+import os
 import torch
 import torch.nn.functional as F
 # from torch.backends import cudnn
@@ -50,7 +52,16 @@ def preprocess(image, input_size):
 
 
 class FastReIDInterface:
-    def __init__(self, config_file, weights_path, device, batch_size=8):
+    def __init__(
+            self,
+            config_file,
+            weights_path,
+            device,
+            batch_size=8,
+            poison_cameras=None,
+            poison_epsilon=0.0,
+            poison_seed=7,
+            export_embeddings=None):
         super(FastReIDInterface, self).__init__()
         if device != 'cpu':
             self.device = 'cuda'
@@ -72,8 +83,20 @@ class FastReIDInterface:
             self.model = self.model.eval()
 
         self.pH, self.pW = self.cfg.INPUT.SIZE_TEST
-
-    def inference(self, image, detections):
+        self.poison_cameras = self._parse_poison_cameras(poison_cameras)
+        self.poison_epsilon = float(poison_epsilon)
+        self.poison_seed = int(poison_seed)
+        self.export_embeddings = export_embeddings
+        self._poison_direction = None
+        if self.export_embeddings:
+            export_dir = os.path.dirname(self.export_embeddings)
+            if export_dir:
+                os.makedirs(export_dir, exist_ok=True)
+            with open(self.export_embeddings, "w", newline="") as f:
+                writer = csv.writer(f)
+                writer.writerow(["camera", "frame", "detection_index", "x1", "y1", "x2", "y2", "embedding"])
+
+    def inference(self, image, detections, camera_id=None, frame_id=None):
 
         if detections is None or np.size(detections) == 0:
             return []
@@ -147,5 +170,50 @@ class FastReIDInterface:
 
             features = np.vstack((features, feat))
 
+        features = self._apply_prime_poison(features, camera_id)
+        self._export_prime_embeddings(features, detections, camera_id, frame_id)
         return features
 
+    def _apply_prime_poison(self, features, camera_id):
+        if (
+                features is None
+                or len(features) == 0
+                or self.poison_epsilon == 0.0
+                or str(camera_id) not in self.poison_cameras):
+            return features
+        if self._poison_direction is None or self._poison_direction.shape[0] != features.shape[1]:
+            rng = np.random.default_rng(self.poison_seed)
+            direction = rng.normal(size=features.shape[1])
+            self._poison_direction = direction / max(np.linalg.norm(direction), 1e-12)
+        poisoned = features + self.poison_epsilon * self._poison_direction
+        return poisoned / np.maximum(np.linalg.norm(poisoned, axis=1, keepdims=True), 1e-12)
+
+    @staticmethod
+    def _parse_poison_cameras(poison_cameras):
+        if poison_cameras is None:
+            return set()
+        if isinstance(poison_cameras, str):
+            return {camera.strip() for camera in poison_cameras.split(",") if camera.strip()}
+        return {str(camera).strip() for camera in poison_cameras if str(camera).strip()}
+
+    def _export_prime_embeddings(self, features, detections, camera_id, frame_id):
+        if not self.export_embeddings or features is None or len(features) == 0:
+            return
+        with open(self.export_embeddings, "a", newline="") as f:
+            writer = csv.writer(f)
+            for detection_index, feature in enumerate(features):
+                if detections is not None and detection_index < len(detections):
+                    x1, y1, x2, y2 = detections[detection_index, :4]
+                else:
+                    x1 = y1 = x2 = y2 = ""
+                writer.writerow([
+                    camera_id,
+                    frame_id,
+                    detection_index,
+                    x1,
+                    y1,
+                    x2,
+                    y2,
+                    " ".join(str(float(value)) for value in feature),
+                ])
+
